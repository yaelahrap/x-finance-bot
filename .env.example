# x-finance-bot Environment Configuration
# Copy this file to .env and fill in your values.

# Application
APP_ENV=development
APP_PORT=8080
APP_BASE_URL=https://bot.yourdomain.com

# AI Provider (Anthropic or OpenAI-compatible like 9Router, vLLM, OpenRouter)
# Set AI_PROVIDER to "anthropic" (default) or "openai" for OpenAI-compatible.
AI_PROVIDER=anthropic
# AI_BASE_URL: required when AI_PROVIDER=openai (e.g. https://api.raflyrama.dev/v1)
# Leave empty for Anthropic (uses https://api.anthropic.com).
AI_BASE_URL=
# AI_API_KEY: bearer token for the chosen provider.
# Falls back to ANTHROPIC_API_KEY for backward compat.
AI_API_KEY=
# AI_MODEL: model identifier
# For Anthropic native: e.g. claude-sonnet-4-5
# For 9Router (kr/): e.g. kr/claude-sonnet-4.5, kr/claude-opus-4.7, kr/auto
AI_MODEL=kr/claude-sonnet-4.5

# Legacy fields (still honored as fallbacks for AI_API_KEY / AI_MODEL)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# X (Twitter) API
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_MEDIA=x-info-bot-media
CLOUDFLARE_R2_BUCKET_ARCHIVES=x-info-bot-archives
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_URL_MEDIA=
CLOUDFLARE_R2_PUBLIC_URL_ARCHIVES=

# Database (SQLite for development)
DATABASE_URL=file:./data/bot.db?cache=shared&_journal=WAL

# Bot Configuration
ADMIN_API_KEY=
POSTING_MODE=manual
MIN_AUTO_POST_SCORE=42
